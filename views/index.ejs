<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>URL Shortener — vijay.tools</title>
  <meta name="description" content="Shorten any URL instantly. Free, no signup required.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* Design direction: Linear/Vercel-meets-terminal — clean dark bg, off-white ink, sharp borders · palette: #0d0d0d surface, #f5f0e8 ink, #e8824a accent (warm orange) · type: Inter + JetBrains Mono */

    :root {
      --bg:          #0d0d0d;
      --bg-raised:   #161616;
      --bg-sunk:     #111111;
      --bg-overlay:  #1c1c1c;
      --ink:         #f5f0e8;
      --ink-soft:    #c9c0b0;
      --ink-muted:   #7a7060;
      --ink-faint:   #3a3530;
      --rule:        #242424;
      --rule-soft:   #1e1e1e;
      --accent:      #e8824a;
      --accent-hover:#d06838;
      --accent-soft: rgba(232,130,74,.12);
      --success:     #4aae74;
      --danger:      #e05050;
      --shadow-1: 0 1px 0 rgba(0,0,0,.18), 0 2px 4px rgba(0,0,0,.14);
      --shadow-2: 0 1px 0 rgba(0,0,0,.20), 0 8px 24px -8px rgba(0,0,0,.40);
      --shadow-3: 0 2px 4px rgba(0,0,0,.24), 0 16px 40px -16px rgba(0,0,0,.50);
      --radius-sm: 6px;
      --radius:    8px;
      --radius-lg: 12px;
      --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      --sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      margin: 0;
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.55;
      color: var(--ink);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* Nav */
    .site-nav {
      position: sticky;
      top: 0;
      z-index: 20;
      border-bottom: 1px solid var(--rule);
      background: rgba(13,13,13,.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .nav-inner {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 24px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: var(--ink);
      font-weight: 600;
      font-size: 14px;
      letter-spacing: -0.01em;
      flex-shrink: 0;
    }
    .brand svg { color: var(--ink-muted); flex-shrink: 0; }
    .brand-dot { color: var(--accent); }
    .nav-meta {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .nav-breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--ink-muted);
      margin-right: 8px;
    }
    .nav-breadcrumb .slash { opacity: .4; }
    .nav-breadcrumb .current { color: var(--ink-soft); }
    .nav-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: var(--radius-sm);
      font-size: 12.5px;
      font-weight: 500;
      color: var(--ink-muted);
      text-decoration: none;
      border: none;
      background: none;
      cursor: pointer;
      transition: color .15s, background .15s;
      white-space: nowrap;
    }
    .nav-link:hover { color: var(--ink-soft); background: var(--bg-overlay); }
    .nav-link-accent {
      color: var(--ink-soft);
      border: 1px solid var(--rule);
      background: var(--bg-raised);
    }
    .nav-link-accent:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-soft); }
    .nav-link-label { font-size: 12.5px; }

    /* Main layout */
    main {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 24px 80px;
    }

    /* Hero */
    .hero {
      padding: 56px 0 40px;
      border-bottom: 1px solid var(--rule);
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 600;
      color: var(--ink-muted);
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .eyebrow-dot {
      display: inline-block;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-soft);
    }
    .hero-title {
      margin: 0 0 12px;
      font-size: clamp(24px, 4vw, 36px);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.15;
      color: var(--ink);
    }
    .hero-title-accent { color: var(--accent); display: block; }
    .hero-sub {
      margin: 0;
      font-size: 14px;
      color: var(--ink-muted);
      max-width: 460px;
      line-height: 1.65;
    }
    .trust-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 20px;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border: 1px solid var(--rule);
      border-radius: 100px;
      font-size: 11px;
      font-weight: 500;
      color: var(--ink-muted);
      letter-spacing: .04em;
      background: var(--bg-raised);
    }

    /* Shorten form */
    .shorten-section { padding: 40px 0 0; }
    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin: 0 0 12px;
    }
    .shorten-form {
      display: flex;
      gap: 8px;
      align-items: stretch;
    }
    .url-input-wrap {
      flex: 1;
      position: relative;
      display: flex;
      align-items: center;
    }
    .url-input-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--ink-faint);
      pointer-events: none;
      display: flex;
    }
    .url-input {
      width: 100%;
      height: 44px;
      padding: 0 12px 0 36px;
      background: var(--bg-raised);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      color: var(--ink);
      font-family: var(--mono);
      font-size: 13px;
      transition: border-color .15s, box-shadow .15s;
      outline: none;
    }
    .url-input::placeholder { color: var(--ink-faint); }
    .url-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-soft);
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      height: 44px;
      padding: 0 20px;
      background: var(--accent);
      color: #1a0d00;
      border: none;
      border-radius: var(--radius);
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background .15s, transform .1s;
      letter-spacing: .01em;
    }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-primary:active { transform: scale(.98); }

    /* Result card */
    .result-section { margin-top: 16px; }
    .result-card {
      background: var(--bg-raised);
      border: 1px solid var(--rule);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-1);
    }
    .result-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      border-bottom: 1px solid var(--rule);
    }
    .result-card-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--ink-muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .result-status-dot {
      display: inline-block;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--success);
    }
    .result-card-body {
      padding: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .result-url {
      flex: 1;
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 500;
      color: var(--accent);
      text-decoration: none;
      word-break: break-all;
      line-height: 1.4;
    }
    .result-url:hover { color: var(--accent-hover); }
    .btn-copy {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      height: 34px;
      background: var(--bg-overlay);
      border: 1px solid var(--rule);
      border-radius: var(--radius-sm);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink-soft);
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
      flex-shrink: 0;
      font-family: var(--sans);
    }
    .btn-copy:hover { border-color: var(--ink-muted); color: var(--ink); background: var(--bg-raised); }
    .btn-copy.copied { border-color: var(--success); color: var(--success); background: rgba(74,174,116,.08); }
    .btn-copy svg { width: 13px; height: 13px; }

    /* Links table */
    .links-section { margin-top: 40px; }
    .links-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .links-table {
      width: 100%;
      border: 1px solid var(--rule);
      border-radius: var(--radius-lg);
      overflow: hidden;
      background: var(--bg-raised);
      box-shadow: var(--shadow-1);
      border-collapse: separate;
      border-spacing: 0;
    }
    .links-table th {
      padding: 10px 16px;
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--ink-muted);
      text-align: left;
      background: var(--bg-sunk);
      border-bottom: 1px solid var(--rule);
    }
    .links-table td {
      padding: 12px 16px;
      font-size: 13px;
      border-bottom: 1px solid var(--rule);
      vertical-align: middle;
      max-width: 0;
    }
    .links-table tr:last-child td { border-bottom: none; }
    .links-table tbody tr:hover td { background: var(--bg-overlay); }
    .td-full { width: 60%; }
    .td-short { width: 40%; }
    .cell-url {
      font-family: var(--mono);
      font-size: 12.5px;
      color: var(--ink-soft);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
      max-width: 100%;
      text-decoration: none;
    }
    .cell-url:hover { color: var(--ink); }
    .cell-short {
      font-family: var(--mono);
      font-size: 12.5px;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
      max-width: 100%;
    }
    .cell-short:hover { color: var(--accent-hover); }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 40px 16px;
      border: 1px dashed var(--rule);
      border-radius: var(--radius-lg);
      background: var(--bg-raised);
    }
    .empty-icon {
      color: var(--ink-faint);
      margin: 0 auto 12px;
      display: flex;
      justify-content: center;
    }
    .empty-title { margin: 0 0 4px; font-size: 13px; font-weight: 600; color: var(--ink-muted); }
    .empty-sub { margin: 0; font-size: 12px; color: var(--ink-faint); }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--bg-overlay);
      border: 1px solid var(--rule);
      color: var(--ink-soft);
      font-size: 13px;
      font-weight: 500;
      padding: 10px 16px;
      border-radius: var(--radius);
      box-shadow: var(--shadow-2);
      opacity: 0;
      pointer-events: none;
      transition: opacity .2s, transform .2s;
      z-index: 1000;
      white-space: nowrap;
    }
    .toast.visible { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.danger  { border-color: var(--danger); color: var(--danger); }
    .toast.success { border-color: var(--success); color: var(--success); }

    /* Support FAB */
    .support-fab {
      position: fixed;
      right: 20px;
      bottom: 20px;
      z-index: 200;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--bg-raised);
      border: 1px solid var(--rule);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-2);
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s;
      color: var(--ink-muted);
      padding: 0;
    }
    .support-fab:hover {
      transform: translateY(-2px) scale(1.04);
      box-shadow: var(--shadow-3);
      border-color: var(--accent);
      color: var(--accent);
    }
    .support-fab:active { transform: translateY(0) scale(1); }
    .support-fab-arc { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
    .support-fab-text {
      fill: var(--ink-muted);
      font-size: 9.5px;
      font-family: var(--sans);
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
    }
    .support-fab:hover .support-fab-text { fill: var(--accent); }
    .support-fab-icon { position: relative; width: 16px; height: 16px; z-index: 1; transition: transform .15s ease; }
    .support-fab:hover .support-fab-icon { transform: rotate(-6deg) scale(1.1); }

    /* Support Dialog */
    .support-dialog {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 500;
      align-items: flex-end;
      justify-content: center;
    }
    @media (min-width: 480px) { .support-dialog { align-items: center; } }
    .support-dialog.open { display: flex; animation: support-fade-in .2s ease-out; }
    .support-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,.72);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .support-panel {
      position: relative;
      width: 100%;
      max-width: 360px;
      background: var(--bg-raised);
      border: 1px solid var(--rule);
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      box-shadow: var(--shadow-3);
      animation: support-slide-up .25s ease-out;
      overflow: hidden;
    }
    @media (min-width: 480px) { .support-panel { border-radius: var(--radius-lg); } }
    .support-close {
      position: absolute;
      top: 12px; right: 12px;
      width: 28px; height: 28px;
      border-radius: var(--radius-sm);
      background: var(--bg-overlay);
      border: 1px solid var(--rule);
      color: var(--ink-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all .15s;
    }
    .support-close:hover { background: var(--bg-sunk); color: var(--ink); border-color: var(--ink-muted); }
    .support-close svg { width: 14px; height: 14px; }
    .support-body { padding: 28px 24px 24px; text-align: center; }
    .support-badge {
      width: 48px; height: 48px;
      border-radius: var(--radius);
      background: var(--accent-soft);
      border: 1px solid rgba(232,130,74,.25);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      color: var(--accent);
    }
    .support-badge svg { width: 24px; height: 24px; overflow: visible; display: block; }
    .support-title { margin: 0 0 6px; font-size: 17px; font-weight: 700; letter-spacing: -.02em; color: var(--ink); }
    .support-sub { margin: 6px auto 0; max-width: 280px; font-size: 12.5px; line-height: 1.6; color: var(--ink-muted); }
    .support-amounts { margin-top: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .support-amount {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 12px 8px;
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      background: var(--bg-overlay);
      text-decoration: none;
      transition: all .15s;
      cursor: pointer;
    }
    .support-amount:hover { border-color: var(--accent); background: var(--accent-soft); }
    .support-amount:hover .support-amount-label { color: var(--accent); }
    .support-amount-label {
      font-size: 10px; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: var(--ink-muted); transition: color .15s;
    }
    .support-amount-value { font-family: var(--mono); font-size: 15px; font-weight: 600; color: var(--ink); }
    .support-qr-wrap { margin-top: 16px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .support-qr-label { margin: 0; font-size: 10px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-muted); }
    .support-qr { padding: 6px; border: 1px solid var(--rule); border-radius: 10px; background: #fff; box-shadow: 0 8px 20px -10px rgba(0,0,0,.4); }
    .support-qr img { width: 180px; height: auto; display: block; border-radius: 5px; }
    .support-copy {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      margin-top: 12px;
      padding: 10px 14px;
      background: var(--bg-overlay);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink-soft);
      cursor: pointer;
      transition: all .15s;
      text-align: left;
    }
    .support-copy:hover { background: var(--bg-sunk); border-color: var(--ink-muted); }
    .support-copy svg { width: 13px; height: 13px; color: var(--ink-muted); margin-left: auto; flex-shrink: 0; }
    .support-copy.copied svg { color: var(--success); }
    .support-hint { margin: 10px 0 0; font-size: 10.5px; color: var(--ink-faint); }
    .support-foot {
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      font-size: 11px;
      color: var(--ink-muted);
    }
    .support-foot svg { width: 11px; height: 11px; color: var(--accent); }
    .support-foot strong { font-weight: 600; color: var(--ink-soft); }
    @keyframes support-fade-in { from { opacity: 0; } to { opacity: 1; } }
    @keyframes support-slide-up { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @media (max-width: 480px) {
      .support-panel { max-width: 100%; }
      .support-fab { right: 14px; bottom: 14px; }
    }

    /* Responsive */
    @media (max-width: 600px) {
      .nav-inner { padding: 0 16px; }
      .nav-breadcrumb { display: none; }
      main { padding: 0 16px 80px; }
      .hero { padding: 36px 0 28px; }
      .shorten-form { flex-direction: column; }
      .btn-primary { width: 100%; justify-content: center; }
      .links-table th:first-child,
      .links-table td:first-child { display: none; }
    }
  </style>
</head>
<body>

  <!-- ===== Nav ===== -->
  <header class="site-nav" role="banner">
    <div class="nav-inner">
      <a href="/" class="brand" aria-label="Vijay Gupta — tools">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h10"/>
        </svg>
        <span class="brand-name">vijay<span class="brand-dot">.</span>tools</span>
      </a>
      <nav class="nav-meta" aria-label="Site meta">
        <span class="nav-breadcrumb">
          <span>Tools</span>
          <span class="slash">/</span>
          <span class="current">URL Shortener</span>
        </span>
        <a href="https://github.com/vijaygupta18" class="nav-link" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.6.5.5 5.6.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.7 1.2 3.4.9.1-.8.4-1.2.7-1.5-2.5-.3-5.2-1.3-5.2-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.5-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5C20.2 21.4 23.5 17 23.5 12 23.5 5.6 18.4.5 12 .5z"/>
          </svg>
          GitHub
        </a>
        <button type="button" class="nav-link nav-link-accent" data-open="support" aria-label="Buy me a chai">
          <svg width="14" height="14" viewBox="2 7 20 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 8h1a4 4 0 0 1 0 8h-1"/>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
          </svg>
          <span class="nav-link-label">Buy me a chai</span>
        </button>
      </nav>
    </div>
  </header>

  <main>

    <!-- ===== Hero ===== -->
    <section class="hero">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        URL tools &middot; Server-side
      </div>
      <h1 class="hero-title">
        Long URLs, made short.
        <span class="hero-title-accent">Paste once, share anywhere.</span>
      </h1>
      <p class="hero-sub">
        Drop any URL and get a compact short link instantly.
        No signup. No tracking dashboard. Just shorter links.
      </p>
      <div class="trust-row">
        <span class="pill">No signup</span>
        <span class="pill">Instant redirect</span>
        <span class="pill">Free</span>
      </div>
    </section>

    <!-- ===== Shorten form ===== -->
    <section class="shorten-section" aria-label="Shorten a URL">
      <p class="section-label">Shorten a URL</p>
      <form action="/shortUrls" method="POST" class="shorten-form" autocomplete="off">
        <label for="fullUrl" class="sr-only">Full URL</label>
        <div class="url-input-wrap">
          <span class="url-input-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </span>
          <input
            required
            type="url"
            name="fullUrl"
            id="fullUrl"
            class="url-input"
            placeholder="https://your-very-long-url.com/goes/here"
            spellcheck="false"
            autocomplete="off"
          >
        </div>
        <button type="submit" class="btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
          Shorten
        </button>
      </form>
    </section>

    <!-- ===== Most recent short URL result ===== -->
    <% if (urlcollection && urlcollection.length > 0) { %>
      <section class="result-section" aria-label="Your short URL">
        <div class="result-card">
          <div class="result-card-head">
            <span class="result-card-label">
              <span class="result-status-dot" aria-hidden="true"></span>
              Short URL ready
            </span>
          </div>
          <div class="result-card-body">
            <a
              href="/<%= urlcollection[0].short %>"
              class="result-url"
              target="_blank"
              rel="noopener"
              aria-label="Open short URL"
            >/<%= urlcollection[0].short %></a>
            <button
              type="button"
              class="btn-copy"
              data-copy="/<%= urlcollection[0].short %>"
              aria-label="Copy short URL"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <span class="copy-label">Copy</span>
            </button>
          </div>
        </div>
      </section>
    <% } %>

    <!-- ===== Links list ===== -->
    <section class="links-section" aria-label="Recent shortened URLs">
      <div class="links-header">
        <p class="section-label" style="margin:0">Recent links</p>
        <% if (urlcollection && urlcollection.length > 0) { %>
          <span class="links-count"><%= urlcollection.length %> link<%= urlcollection.length !== 1 ? 's' : '' %></span>
        <% } %>
      </div>

      <% if (!urlcollection || urlcollection.length === 0) { %>
        <div class="empty-state" role="status">
          <div class="empty-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </div>
          <p class="empty-title">No links yet</p>
          <p class="empty-sub">Paste a URL above and hit Shorten to create your first short link.</p>
        </div>
      <% } else { %>
        <table class="links-table" aria-label="Shortened URLs">
          <thead>
            <tr>
              <th class="td-full" scope="col">Original URL</th>
              <th class="td-short" scope="col">Short URL</th>
            </tr>
          </thead>
          <tbody>
            <% urlcollection.forEach(function(url) { %>
              <tr>
                <td class="td-full">
                  <a href="<%= url.full %>" class="cell-url" target="_blank" rel="noopener" title="<%= url.full %>">
                    <%= url.full %>
                  </a>
                </td>
                <td class="td-short">
                  <a href="/<%= url.short %>" class="cell-short" target="_blank" rel="noopener">
                    /<%= url.short %>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

  </main>

  <!-- ===== Toast ===== -->
  <div id="toast" class="toast" role="status" aria-live="polite"></div>

  <!-- ===== Support FAB ===== -->
  <button id="supportFab" class="support-fab" aria-label="Buy me a coffee" title="Buy me a coffee — support this project">
    <svg viewBox="0 0 100 100" class="support-fab-arc" aria-hidden="true">
      <defs>
        <path id="bmcArc" d="M 16,50 A 34,34 0 0,1 84,50" fill="none"/>
      </defs>
      <text class="support-fab-text">
        <textPath href="#bmcArc" startOffset="50%" text-anchor="middle">BUY ME A COFFEE</textPath>
      </text>
    </svg>
    <svg class="support-fab-icon" viewBox="2 7 20 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M17 8h1a4 4 0 0 1 0 8h-1"/>
      <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
    </svg>
  </button>

  <!-- ===== Support Dialog ===== -->
  <div id="supportDialog" class="support-dialog" aria-hidden="true" role="dialog" aria-labelledby="supportTitle">
    <div class="support-backdrop" data-close></div>
    <div class="support-panel" role="document">
      <button class="support-close" data-close aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <div class="support-body">
        <div class="support-badge">
          <svg viewBox="2 7 20 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 8h1a4 4 0 0 1 0 8h-1"/>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
          </svg>
        </div>
        <h2 id="supportTitle" class="support-title">Enjoying vijay.tools?</h2>
        <p class="support-sub">If this saved you time on a project, a chai goes a long way to keep these tools free &amp; open.</p>
        <div class="support-amounts">
          <a id="amount49" class="support-amount" href="#">
            <span class="support-amount-label">Chai</span>
            <span class="support-amount-value">&#8377;49</span>
          </a>
          <a id="amount99" class="support-amount" href="#">
            <span class="support-amount-label">Coffee</span>
            <span class="support-amount-value">&#8377;99</span>
          </a>
        </div>
        <div class="support-qr-wrap">
          <p class="support-qr-label">Or scan with any UPI app</p>
          <div class="support-qr">
            <img
              src="https://raw.githubusercontent.com/vijaygupta18/system-design-simulator/main/public/support-upi-qr.jpg"
              alt="UPI QR code — scan to support Vijay Gupta"
              loading="lazy"
            />
          </div>
        </div>
        <button id="supportCopyBtn" class="support-copy" type="button">
          <span id="supportUpiId">vijaygupta1818@ptyes</span>
          <svg id="supportCopyIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
        </button>
        <p class="support-hint">Pay what feels right &middot; No pressure &middot; No ads</p>
        <div class="support-foot">
          <span>Built with</span>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 21s-7-4.5-7-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 5.5-7 10-7 10z"/>
          </svg>
          <span>by <strong>Vijay Gupta</strong></span>
        </div>
      </div>
    </div>
  </div>

  <script>
    /* vijay.tools — URL Shortener client interactions */

    // Toast
    let _toastTimer = null;
    function toast(msg, type) {
      var el = document.getElementById('toast');
      el.textContent = msg;
      el.className = 'toast ' + (type || 'success') + ' visible';
      clearTimeout(_toastTimer);
      _toastTimer = setTimeout(function() { el.classList.remove('visible'); }, 2800);
    }

    // Copy buttons
    document.querySelectorAll('.btn-copy[data-copy]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var text = btn.dataset.copy;
        try {
          await navigator.clipboard.writeText(text);
          var label = btn.querySelector('.copy-label');
          if (label) {
            var orig = label.textContent;
            label.textContent = 'Copied';
            btn.classList.add('copied');
            setTimeout(function() {
              label.textContent = orig;
              btn.classList.remove('copied');
            }, 2000);
          }
          toast('Copied to clipboard', 'success');
        } catch(e) {
          toast('Copy failed — select and copy manually', 'danger');
        }
      });
    });

    // Support dialog
    var BMC_UPI_ID   = 'vijaygupta1818@ptyes';
    var BMC_UPI_NAME = 'Vijay Gupta';
    var BMC_TN       = 'vijay.tools support';

    function buildUpiIntent(amount) {
      var params = new URLSearchParams({ pa: BMC_UPI_ID, pn: BMC_UPI_NAME, cu: 'INR', tn: BMC_TN });
      if (amount) params.set('am', String(amount));
      return 'upi://pay?' + params.toString();
    }

    (function wireSupportDialog() {
      var dialog  = document.getElementById('supportDialog');
      var copyBtn = document.getElementById('supportCopyBtn');
      var amt49   = document.getElementById('amount49');
      var amt99   = document.getElementById('amount99');
      if (!dialog) return;

      if (amt49) amt49.href = buildUpiIntent(49);
      if (amt99) amt99.href = buildUpiIntent(99);

      var openDialog = function() {
        dialog.classList.add('open');
        dialog.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };
      var closeDialog = function() {
        dialog.classList.remove('open');
        dialog.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      document.querySelectorAll('[data-open="support"], #supportFab').forEach(function(el) {
        el.addEventListener('click', openDialog);
      });
      dialog.addEventListener('click', function(e) {
        if (e.target.closest('[data-close]')) closeDialog();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && dialog.classList.contains('open')) closeDialog();
      });

      if (copyBtn) {
        var icon = document.getElementById('supportCopyIcon');
        var original = icon ? icon.innerHTML : '';
        copyBtn.addEventListener('click', async function() {
          try {
            await navigator.clipboard.writeText(BMC_UPI_ID);
            copyBtn.classList.add('copied');
            if (icon) icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
            setTimeout(function() {
              copyBtn.classList.remove('copied');
              if (icon) icon.innerHTML = original;
            }, 2000);
          } catch(e) {
            toast('Copy failed — long-press to copy manually', 'danger');
          }
        });
      }
    })();
  </script>

</body>
</html>
